---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.excerpt}>
  <Navbar />
  <main class="section blog-post-page">
    <article class="blog-article container">
      <!-- Hero -->
      <div class="blog-hero" style={`background: ${post.data.coverGradient};`}>
        <div class="blog-hero-overlay"></div>
        <div class="blog-hero-content">
          <div class="blog-hero-meta">
            <span class="blog-hero-date">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"
                ></rect><line x1="16" y1="2" x2="16" y2="6"></line><line
                  x1="8"
                  y1="2"
                  x2="8"
                  y2="6"></line><line x1="3" y1="10" x2="21" y2="10"
                ></line></svg
              >
              {
                post.data.date.toLocaleDateString("en-US", {
                  month: "long",
                  day: "numeric",
                  year: "numeric",
                })
              }
            </span>
          </div>
          <h1 class="blog-hero-title">{post.data.title}</h1>
          <p class="blog-hero-excerpt">{post.data.excerpt}</p>
          <div class="blog-hero-tags">
            {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </div>
      </div>

      <!-- Body -->
      <div class="blog-body">
        <Content />
      </div>

      <!-- Footer navigation -->
      <div class="blog-footer-nav">
        <a href="/blog" class="blog-back-link">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="19" y1="12" x2="5" y2="12"></line><polyline
              points="12 19 5 12 12 5"></polyline></svg
          >
          Back to all posts
        </a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .blog-post-page {
    padding-top: var(--nav-height);
  }

  .blog-article {
    max-width: 780px;
    margin-inline: auto;
    padding-bottom: var(--space-16);
  }

  /* ── Hero ── */
  .blog-hero {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    position: relative;
    padding: var(--space-16) var(--space-8) var(--space-10);
    margin-bottom: var(--space-12);
    margin-top: var(--space-8);
  }

  .blog-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      var(--color-bg-primary) 0%,
      transparent 100%
    );
  }

  .blog-hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .blog-hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    font-weight: var(--font-weight-medium);
  }

  .blog-hero-date {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  .blog-hero-title {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: #ffffff;
    max-width: 680px;
    transition: color var(--transition-base);
  }

  .blog-hero-excerpt {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    max-width: 600px;
    transition: color var(--transition-base);
  }

  :root[data-theme="light"] .blog-hero {
    background: var(--color-bg-secondary) !important;
    border: 1px solid var(--color-border);
  }

  :root[data-theme="light"] .blog-hero-title {
    color: var(--color-text-primary);
  }

  :root[data-theme="light"] .blog-hero-excerpt {
    color: var(--color-text-secondary);
  }

  :root[data-theme="light"] .blog-hero-overlay {
    background: linear-gradient(
      to top,
      var(--color-bg-primary) 0%,
      rgba(255, 255, 255, 0.1) 100%
    );
  }

  .blog-hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* ── Body Content (rendered markdown) ── */
  .blog-body {
    line-height: 1.8;
    color: var(--color-text-secondary);
    font-size: var(--font-size-base);
  }

  .blog-body :global(h2) {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    line-height: var(--line-height-tight);
  }

  .blog-body :global(h3) {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .blog-body :global(p) {
    margin-bottom: var(--space-5);
  }

  .blog-body :global(ul),
  .blog-body :global(ol) {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }

  .blog-body :global(li) {
    margin-bottom: var(--space-2);
    line-height: 1.7;
  }

  .blog-body :global(li)::marker {
    color: var(--color-accent);
  }

  .blog-body :global(ol li)::marker {
    color: var(--color-accent);
    font-weight: var(--font-weight-bold);
  }

  .blog-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .blog-body :global(a:hover) {
    color: var(--color-accent-hover, var(--color-accent));
  }

  .blog-body :global(code:not(pre code)) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-accent-subtle);
    color: var(--color-accent);
    padding: 2px 6px;
    border-radius: var(--border-radius-sm);
  }

  .blog-body :global(pre) {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-5);
    overflow-x: auto;
    margin-bottom: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--color-text-primary);
    -webkit-overflow-scrolling: touch;
  }

  .blog-body :global(strong) {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
  }

  .blog-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--border-radius-lg);
    margin-block: var(--space-6);
  }

  .blog-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-5);
    margin-block: var(--space-6);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .blog-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: var(--space-8);
  }

  /* ── Footer nav ── */
  .blog-footer-nav {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .blog-back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
    text-decoration: none;
    transition: gap var(--transition-fast);
  }

  .blog-back-link:hover {
    gap: var(--space-3);
  }

  @media (max-width: 640px) {
    .blog-hero {
      padding: var(--space-10) var(--space-5) var(--space-8);
    }

    .blog-hero-title {
      font-size: var(--font-size-2xl);
    }

    .blog-hero-excerpt {
      font-size: var(--font-size-base);
    }
  }
</style>
