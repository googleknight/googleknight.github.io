---
import { Image } from "astro:assets";
import shubhamImage from "../assets/shubham.jpg";

const startDate = new Date("2018-01-10");
const today = new Date();
const yearsDiff = today.getFullYear() - startDate.getFullYear();
const monthDiff = today.getMonth() - startDate.getMonth();
const totalYears =
  monthDiff < 0 || (monthDiff === 0 && today.getDate() < startDate.getDate())
    ? yearsDiff - 1
    : yearsDiff;

const stats = [
  { value: `${totalYears}+`, label: "Years Experience" },
  { value: "35M+", label: "Users Impacted" },
  { value: "7+", label: "Product Domains" },
];
---

<section class="section-alt" id="about">
  <div class="container">
    <h2 class="section-heading reveal">
      <span class="accent-underline">About Me</span>
    </h2>
    <p class="section-subheading reveal">A little bit about my journey</p>

    <div class="about-grid">
      <div class="about-image-wrapper reveal">
        <Image
          src={shubhamImage}
          alt="Shubham Mathur — Staff Software Engineer"
          class="about-image"
          widths={[320, 400, 640, 800]}
          sizes="(max-width: 480px) 280px, (max-width: 992px) 320px, 400px"
          loading="lazy"
          decoding="async"
          quality={100}
        />
      </div>

      <div class="about-content reveal">
        <div class="about-text">
          <p>
            I'm a full-stack engineer with a backend lean, drawn to problems
            where scale runs into real-world constraints: security, compliance,
            and systems that can't afford to be wrong. Most of my work over the
            past <strong>{totalYears} years</strong> has been distributed
            systems, identity and auth, and the backend platforms underneath
            them, but I ship the frontend that sits on top when a problem needs
            it end to end.
          </p>
          <p>
            Right now I'm at <strong>Civilgrid</strong>, working on the GIS
            platform and helping build out the India engineering team.
          </p>
          <p>
            Before this, I spent two years at <strong>Vimeo</strong> owning
            identity and compliance for <strong>4.5M+ users</strong>. I designed
            a zero-trust architecture for age assurance under the UK Online
            Safety Act and EU DSA, rebuilt a deactivation pipeline that went
            from 2 days to under 5 minutes, and led a Go service that pulled
            authentication out of a 15-year-old PHP monolith. I also shipped
            VimeoIQ, an internal RAG assistant on Vertex AI, in about eight
            weeks.
          </p>
          <p>
            Before Vimeo, six years at <strong>McKinsey &amp; Company</strong>
            building for Fortune 500 clients across <strong
              >banking, healthcare, insurance, and telecom</strong
            >, with teams in Singapore, Malaysia, Thailand, and the US.
          </p>
          <p>
            Outside work I contribute to open source (merged fixes into Apple,
            Wise, and Stripe), build side projects like a CRDT library and a
            workflow engine, and spend time on cooking, running, and strength
            training.
          </p>
        </div>
      </div>
    </div>

    <div class="stats-grid">
      {
        stats.map((stat) => (
          <div class="stat-card glass-card reveal">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-12);
    align-items: center;
    margin-bottom: var(--space-12);
  }

  .about-image-wrapper {
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
  }

  .about-image {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: top center;
    border-radius: var(--border-radius-2xl);
    border: 2px solid var(--color-border);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 0 0 1px var(--color-accent-subtle);
    transform: rotate(-2deg);
    transition:
      transform var(--transition-slow) ease,
      box-shadow var(--transition-base);
  }

  .about-image:hover {
    transform: rotate(0deg) scale(1.02);
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.35),
      0 0 0 2px var(--color-accent-glow);
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .about-text p {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    line-height: 1.75;
  }

  .about-text strong {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
  }

  .stats-grid {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    max-width: 760px;
    margin-inline: auto;
    width: 100%;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-4);
    text-align: center;
  }

  .stat-value {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    background: linear-gradient(
      135deg,
      var(--color-gradient-start),
      var(--color-gradient-end)
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .stat-label {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-weight: var(--font-weight-medium);
  }

  @media (max-width: 992px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
      text-align: center;
    }

    .about-image {
      transform: rotate(0deg);
      max-width: 320px;
      margin: 0 auto;
    }

    .about-text {
      text-align: left;
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
      max-width: 280px;
    }
  }
</style>
